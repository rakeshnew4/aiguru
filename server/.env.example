# ═════════════════════════════════════════════════════════════════════════════
# AI Teacher Backend — Environment Configuration
# ═════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values

# ─── LiteLLM Proxy (Optional but Recommended) ─────────────────────────────────
# Enable per-user API key management and usage tracking
USE_LITELLM_PROXY=True
LITELLM_PROXY_URL=http://localhost:8005
LITELLM_MASTER_KEY=sk-1234567890abcdefghijklmnopqrstuvwxyz
LITELLM_ADMIN_URL=http://localhost:8006
LITELLM_DATABASE_URL=postgresql://litellm:litellm_secure_password_2024@localhost:5432/litellm_db

# ─── LLM Provider API Keys ───────────────────────────────────────────────────
# Get these from:
# - Gemini: https://aistudio.google.com/app/apikey
# - Anthropic Claude: https://console.anthropic.com/
# - Groq: https://console.groq.com/
# - OpenAI: https://platform.openai.com/api-keys

# Google Gemini (required)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Groq (free tier, optional)
GROQ_API_KEY=your-groq-api-key-here

# OpenAI GPT-4 (optional)
OPENAI_API_KEY=your-openai-api-key-here

# ─── Payment Processing ─────────────────────────────────────────────────────
# Razorpay (India payments)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ─── Firebase (User Auth & Firestore) ───────────────────────────────────────
# Path to Firebase service account JSON (for admin SDK).
# The SDK is used for TWO purposes:
#   1. Verifying Firebase ID tokens from the Android app (all API endpoints).
#   2. Reading/writing Firestore (payments, user records).
# Download from Firebase Console → Project Settings → Service Accounts.
FIREBASE_SERVICE_ACCOUNT=./firebase_serviceaccount.json

# ─── Auth Notes ──────────────────────────────────────────────────────────────
# Every protected endpoint requires: Authorization: Bearer <firebase-id-token>
# The token is obtained on Android via:
#   FirebaseAuth.getInstance().currentUser?.getIdToken(false)
# Tokens expire after 1 hour; the Android TokenManager auto-refreshes them.
# Endpoints NOT requiring auth:  /health, /admin/api/*, /payments/razorpay/webhook
# Endpoints REQUIRING uid match: /payments/razorpay/create-order (token.uid == user_id)
#                                /payments/razorpay/verify        (token.uid == user_id)
#                                /users/register                  (token.uid == userId)

# ─── Admin Portal ────────────────────────────────────────────────────────────
# HTTP Basic Auth credentials (CHANGE IN PRODUCTION)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ─── Redis Cache (Optional, required for some features) ─────────────────────
REDIS_URL=redis://localhost:6379

# ─── Model Tier Configuration ───────────────────────────────────────────────
# These are optional — defaults are already configured in app/core/config.py

# Power tier (best quality) — defaults to Claude 3.5 Sonnet
POWER_PROVIDER=gemini
POWER_MODEL_ID=gemini-3.1-flash-lite-preview
POWER_TEMPERATURE=0.7
POWER_MAX_TOKENS=8192

# Cheaper tier (balanced) — defaults to Gemini 2.5 Flash
CHEAPER_PROVIDER=gemini
CHEAPER_MODEL_ID=gemini-3.1-flash-lite-preview
CHEAPER_TEMPERATURE=0.7
CHEAPER_MAX_TOKENS=4096

# Faster tier (low latency) — defaults to Gemini 2.0 Flash
FASTER_PROVIDER=gemini
FASTER_MODEL_ID=gemini-3.1-flash-lite-preview
FASTER_TEMPERATURE=0.4
FASTER_MAX_TOKENS=1500

# ─── AWS Bedrock (Optional, for Claude via AWS) ────────────────────────────
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1
# AWS_BEARER_TOKEN_BEDROCK=your-bearer-token

# ─── CORS & Origin Allow-list ──────────────────────────────────────────────
# Comma-separated list of allowed origins (e.g., yourapp.com, mobile.yourapp.com)
# Empty = only current server IP allowed
ALLOWED_ORIGINS=

# ─── Server API Key (For inter-service calls) ──────────────────────────────
SERVER_API_KEY=your-secure-api-key-here

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

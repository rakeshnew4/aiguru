<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@null"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/chapterTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chapter"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary"
            android:paddingStart="8dp"
            android:maxLines="1"
            android:ellipsize="end" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/notesButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Notes"
            android:textSize="13sp"
            android:textColor="@color/colorPrimary"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/colorPrimaryLight"
            app:cornerRadius="18dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp" />

    </LinearLayout>

    <!-- Indigo accent line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/colorPrimary" />

    <!-- Tab strip: Pages | Chat -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:tabIndicatorColor="@color/colorPrimary"
        app:tabSelectedTextColor="@color/colorPrimary"
        app:tabTextColor="#888888"
        app:tabMode="fixed"
        app:tabGravity="fill"
        android:elevation="2dp" />

    <!-- ── Pages tab content (Tab 0) ──────────────────────── -->
    <LinearLayout
        android:id="@+id/pagesContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- NCERT attribution — shown only for NCERT chapters -->
        <TextView
            android:id="@+id/ncertAttributionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 Source: NCERT (ncert.nic.in) — Free textbooks by Government of India"
            android:textSize="11sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:background="#EEF2FF"
            android:visibility="gone" />

        <!-- Mastery card (always GONE - kept for compat) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/masteryCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/masteryScoreText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <ProgressBar
                    android:id="@+id/masteryProgressBar"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:layout_marginTop="8dp"
                    android:progress="0" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Pages list + download overlay wrapper -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
                android:id="@+id/chapterSwipeRefresh"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/pagesList"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingTop="12dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:clipToPadding="false" />

            </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

            <!-- NCERT download / PDF loading overlay -->
            <LinearLayout
                android:id="@+id/downloadOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/colorBackground"
                android:visibility="gone">

                <com.aiguruapp.student.widget.BoxSpinnerView
                    android:id="@+id/downloadSpinner"
                    android:layout_width="64dp"
                    android:layout_height="64dp" />

                <TextView
                    android:id="@+id/downloadStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Downloading…"
                    android:textSize="14sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/downloadSubText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="This only happens once"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </FrameLayout>

        <!-- Bottom action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startQuizButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="6dp"
                android:text="🧠  Take AI Quiz"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                app:backgroundTint="@color/colorSecondary"
                app:cornerRadius="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/uploadImageButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Create a Page"
                    android:textSize="13sp"
                    android:textColor="@color/colorPrimary"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorPrimaryLight"
                    app:cornerRadius="14dp"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- ── Chat tab content (Tab 1) — loaded lazily ──────── -->
    <FrameLayout
        android:id="@+id/chatTabContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    >

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#1A1A2E2E"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💬 Chat Review"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/reviewSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select messages to build a quiz"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Selected count badge -->
        <TextView
            android:id="@+id/selectedCountBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:textColor="#5C5BD4"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingEnd="4dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="3dp" android:background="#5C35B5" />

    <!-- Subject + Chapter selectors -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F8F8FF"
        android:padding="12dp"
        android:elevation="1dp">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/subjectInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="Subject">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/subjectInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionNext"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/chapterInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:hint="Chapter">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chapterInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:singleLine="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/loadMessagesButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Load"
            android:textSize="13sp"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />

    </LinearLayout>

    <!-- Select-all bar (shown when messages loaded) -->
    <LinearLayout
        android:id="@+id/selectAllBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#EEEEFF"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/selectAllCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textSize="13sp"
            android:layout_weight="1"
            android:buttonTint="#5C35B5" />

        <TextView
            android:id="@+id/filterLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI replies only"
            android:textSize="12sp"
            android:textColor="#5C5BD4" />

        <CheckBox
            android:id="@+id/aiOnlyCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:buttonTint="#5C35B5" />

    </LinearLayout>

    <!-- Messages list + loading + empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/messagesLoadingBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/messagesEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="📭 No messages found\nCheck the subject and chapter then tap Load"
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary"
            android:lineSpacingExtra="4dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:id="@+id/actionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="12dp">

        <!-- Quiz config row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Count:"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginEnd="6dp" />

            <Spinner
                android:id="@+id/countSpinner"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Type:"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginEnd="6dp" />

            <CheckBox
                android:id="@+id/cbMcq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MCQ"
                android:textSize="12sp"
                android:checked="true"
                android:layout_marginEnd="6dp" />

            <CheckBox
                android:id="@+id/cbShortAnswer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short"
                android:textSize="12sp"
                android:layout_marginEnd="6dp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generateQuizButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🎯 Generate Quiz from Selected Messages"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:enabled="false"
            app:cornerRadius="10dp" />

    </LinearLayout>

</LinearLayout>

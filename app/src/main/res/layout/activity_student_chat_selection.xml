<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="#1A1A2E2E"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✂️ Select Messages"
                android:textColor="@color/colorTextPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selectionSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create notes or quiz from selected messages"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Selected count badge -->
        <TextView
            android:id="@+id/selectedCountBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#5C5BD4"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingEnd="4dp" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="3dp" android:background="#5C35B5" />

    <!-- Select-all / filter bar (shown after messages load) -->
    <LinearLayout
        android:id="@+id/selectAllBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="#EEEEFF"
        android:visibility="gone">

        <CheckBox
            android:id="@+id/selectAllCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select All"
            android:textSize="13sp"
            android:layout_weight="1"
            android:buttonTint="#5C35B5" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI replies only"
            android:textSize="12sp"
            android:textColor="#5C5BD4" />

        <CheckBox
            android:id="@+id/aiOnlyCheckbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="false"
            android:buttonTint="#5C35B5" />

    </LinearLayout>

    <!-- Messages list + loading + empty state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesList"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/messagesLoadingBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/messagesEmptyHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="💬 No chat history yet\nStart a conversation first, then come back here to select messages."
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary"
            android:lineSpacingExtra="4dp"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Bottom action bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="12dp">

        <!-- Quiz options row (shown only when quiz button is relevant) -->
        <LinearLayout
            android:id="@+id/quizOptionsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quiz:"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginEnd="6dp" />

            <Spinner
                android:id="@+id/countSpinner"
                android:layout_width="70dp"
                android:layout_height="36dp"
                android:layout_marginEnd="12dp" />

            <CheckBox
                android:id="@+id/cbMcq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MCQ"
                android:textSize="12sp"
                android:checked="true"
                android:layout_marginEnd="8dp"
                android:buttonTint="#5C35B5" />

            <CheckBox
                android:id="@+id/cbShortAnswer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Short Ans"
                android:textSize="12sp"
                android:checked="false"
                android:buttonTint="#5C35B5" />

        </LinearLayout>

        <!-- Action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveNotesButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📝 Save as Notes"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:enabled="false"
                app:backgroundTint="#1A4CAF50"
                app:strokeColor="#4CAF50"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#2E7D32" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/generateQuizButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🎯 Generate Quiz"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:enabled="false"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="12dp"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  item_smart_card.xml
  A single horizontal smart suggestion card shown in the home screen "For You" strip.
  Width is fixed (220dp) so multiple cards fit in a HorizontalScrollView.
  The left accent strip color is set in code via View.backgroundTintList.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/smartCardRoot"
    android:layout_width="220dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="10dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/colorSurface"
    app:rippleColor="#22000000">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Colored left accent strip — tinted in code to match card type -->
        <View
            android:id="@+id/smartCardAccent"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#1565C0" />

        <!-- Card body -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Emoji + title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/smartCardEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📐"
                    android:textSize="20sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/smartCardTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Card Title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:maxLines="2"
                    android:ellipsize="end" />

            </LinearLayout>

            <!-- Subtitle -->
            <TextView
                android:id="@+id/smartCardSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card subtitle text"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="10dp"
                android:lineSpacingMultiplier="1.25" />

            <!-- CTA label -->
            <TextView
                android:id="@+id/smartCardCta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Try it →"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1565C0" />

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

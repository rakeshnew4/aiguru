<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile header -->
        <LinearLayout
            android:id="@+id/profileHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@color/colorPrimary"
            android:paddingTop="32dp"
            android:paddingBottom="28dp">

            <ImageButton
                android:id="@+id/profileBackButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:layout_gravity="start"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/profileAvatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:gravity="center"
                android:text="👨‍🎤"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:background="@drawable/bg_avatar_circle" />

            <TextView
                android:id="@+id/profileHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Name"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/profileHeaderSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grade 9"
                android:textColor="#CCE0FF"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Edit form -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Name"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileEmailInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Grade"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/profileGradeSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="10dp"
                    android:layout_marginBottom="14dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Student ID"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="School"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/profileSchool"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveProfileButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Save Changes"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="14dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Plan section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Plan"
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:id="@+id/profilePlanText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Free"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/managePlanButton"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Upgrade"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="20dp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Share & Earn (Referral) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎁 Share &amp; Earn"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Refer a friend and you both earn bonus questions every day!"
                    android:textSize="13sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginBottom="16dp" />

                <!-- Referral code row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Your code:"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextSecondary" />

                    <TextView
                        android:id="@+id/referralCodeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--------"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:letterSpacing="0.12"
                        android:layout_marginEnd="8dp" />

                    <ImageButton
                        android:id="@+id/referralCopyButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_copy"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Copy referral code"
                        app:tint="@color/colorPrimary" />

                </LinearLayout>

                <!-- Share button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/referralShareButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="📤 Share My Code"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="12dp"
                    android:layout_marginBottom="10dp" />

                <!-- Claim button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/claimReferralButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Enter a Friend's Code"
                    android:textSize="14sp"
                    android:textColor="@color/colorPrimary"
                    app:backgroundTint="@android:color/transparent"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="1dp"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Rate App -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/rateAppButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="⭐ Rate AfterClassAI"
            android:textSize="15sp"
            android:textColor="@color/colorPrimary"
            app:backgroundTint="#FFF8E1"
            app:cornerRadius="14dp"
            app:strokeColor="@color/colorPrimary"
            app:strokeWidth="1dp" />

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="Logout"
            android:textSize="15sp"
            android:textColor="@color/colorError"
            app:backgroundTint="@color/colorErrorLight"
            app:cornerRadius="14dp"
            app:strokeColor="@color/colorError"
            app:strokeWidth="1dp" />

        <!-- Delete Account (danger zone) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteAccountButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            android:text="Delete Account"
            android:textSize="15sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#B71C1C"
            app:cornerRadius="14dp" />

    </LinearLayout>

</ScrollView>

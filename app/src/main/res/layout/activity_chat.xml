<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F6FA"
    android:fitsSystemWindows="true"
    tools:context=".ChatActivity">

    <!-- ── Toolbar ─────────────────────────────────────────────────── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        app:titleTextColor="#111827"
        app:subtitleTextColor="#6B7280"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:elevation="3dp" />

    <!-- ── Hidden quick-action chips (IDs preserved; code still works) ── -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:gravity="center_vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/explainButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Explain"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/quizButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Quiz Me"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/formulaButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Formulas"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/practiceButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Practice"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/notesButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Notes"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveNotesButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Save Notes"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewNotesButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="View Notes"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/flashcardsButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Flashcards"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                app:backgroundTint="#EEF2FF"
                app:cornerRadius="18dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ── Messages ──────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="520dp"
        android:layout_weight="1"
        android:background="#00000000"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingTop="8dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp"
        tools:listitem="@android:layout/simple_list_item_1" />

    <!-- ── Image Preview Strip ───────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/imagePreviewStrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F9FAFB"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/imagePreviewThumbnail"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="10dp"
            android:contentDescription="Image preview" />

        <TextView
            android:id="@+id/imagePreviewLabel"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Image selected — ask anything"
            android:textSize="13sp"
            android:textColor="#374151" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/removeImageButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="0dp"
            android:text="X"
            android:textSize="14sp"
            android:textColor="#9CA3AF"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

    <!-- ── AI Thinking Indicator ─────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="AI"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_avatar_circle"
            android:layout_marginEnd="10dp" />

        <ProgressBar
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:indeterminateTint="#9CA3AF"
            android:layout_marginEnd="8dp"
            style="@style/Widget.AppCompat.ProgressBar" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thinking..."
            android:textSize="13sp"
            android:textStyle="italic"
            android:textColor="#9CA3AF" />

    </LinearLayout>

    <!-- ── Bottom Input Section ──────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:background="#E8EAED" />

        <!-- Voice Chat Active Bar -->
        <LinearLayout
            android:id="@+id/voiceChatBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FAFAFA"
            android:paddingStart="14dp"
            android:paddingEnd="10dp"
            android:paddingTop="8dp"
            android:visibility="gone">

            <!-- Animated equaliser wave bars -->
            <LinearLayout
                android:id="@+id/waveBarContainer"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="8dp"
                android:clipChildren="false"
                android:visibility="gone">

                <View
                    android:id="@+id/waveBar1"
                    android:layout_width="3dp"
                    android:layout_height="8dp"
                    android:background="#1565C0"
                    android:layout_marginEnd="3dp" />

                <View
                    android:id="@+id/waveBar2"
                    android:layout_width="3dp"
                    android:layout_height="16dp"
                    android:background="#1565C0"
                    android:layout_marginEnd="3dp" />

                <View
                    android:id="@+id/waveBar3"
                    android:layout_width="3dp"
                    android:layout_height="12dp"
                    android:background="#1565C0"
                    android:layout_marginEnd="3dp" />

                <View
                    android:id="@+id/waveBar4"
                    android:layout_width="3dp"
                    android:layout_height="6dp"
                    android:background="#1565C0" />

            </LinearLayout>

            <TextView
                android:id="@+id/voiceChatStatus"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Listening..."
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#111827" />


        </LinearLayout>

        <!-- Listening Indicator (single-shot mic) -->
        <TextView
            android:id="@+id/listeningIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listening... speak now"
            android:textSize="12sp"
            android:textColor="#DC2626"
            android:textStyle="italic"
            android:gravity="center"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

        <!-- Bottom quick-action chips -->
        <HorizontalScrollView
            android:id="@+id/bottomQuickActionsScroll"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:scrollbars="none"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="6dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                >




                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bottomDescribeButton"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:minHeight="0dp"
                    android:text="Describe Image"
                    android:textSize="11sp"
                    android:textColor="#374151"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    app:strokeColor="#E5E7EB"
                    app:cornerRadius="15dp"
                    app:backgroundTint="#00000000"
                    android:visibility="gone" />
                <!-- Attach: Image -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/imageButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="0dp"
                    android:text="&#128247;"
                    android:layout_marginStart="15dp"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />


                <!-- Attach: PDF -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pdfButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="0dp"
                    android:text="&#128196;"
                    android:textSize="18sp"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_marginEnd="4dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/autoExplainButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="0dp"
                    android:text="&#128105;&#8205;&#127979;"
                    android:textSize="25sp"
                    app:backgroundTint="#F3F4F6"
                    app:cornerRadius="22dp"
                    app:rippleColor="#22000000"
                    android:layout_marginStart="60dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                <!-- Single-turn Mic -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voiceButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="0dp"
                    android:text="&#127908;"
                    android:textSize="19sp"
                    app:backgroundTint="#E8F5E9"
                    app:cornerRadius="22dp"
                    android:layout_marginStart="80dp"
                    style="@style/Animation.Design.BottomSheetDialog"/>
                <!-- Auto Explain Mode: auto-launch blackboard on every bot reply -->

                <!-- AI Guru Live Voice Chat -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voiceChatButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="0dp"
                    android:text="&#127897;"
                    android:textSize="19sp"
                    app:backgroundTint="#E8F5E9"
                    app:cornerRadius="22dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ── Main Input Row ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="10dp">


            <!-- Text Input -->
            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Message AI Guru..."
                android:minLines="1"
                android:maxLines="5"
                android:background="@drawable/rounded_edittext_bg"
                android:padding="10dp"
                android:textSize="15sp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:inputType="textMultiLine|textCapSentences"
                android:imeOptions="flagNoEnterAction" />






            <!-- Send -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="0dp"
                android:text="&#10148;"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="4dp"
                app:backgroundTint="#1565C0"
                app:cornerRadius="22dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

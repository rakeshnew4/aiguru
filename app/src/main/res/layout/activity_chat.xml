<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ChatActivity">

    <!-- ── Main content ──────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/colorBackground">

        <!-- ── Header ──────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/chatHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/chapterIconBadge"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="📘"
                android:textSize="17sp"
                android:background="@drawable/bg_chapter_number" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chatHeaderTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chapter"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/chatHeaderSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Subject · Tutor Session"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/languageButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minHeight="0dp"
                android:text="Language ▾"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                app:backgroundTint="@color/colorBackground"
                app:strokeColor="@color/colorDivider"
                app:strokeWidth="1dp"
                app:cornerRadius="18dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openPagesDrawerButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="Pages"
                android:textSize="12sp"
                android:textColor="@color/colorPrimary"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorPrimaryLight"
                app:cornerRadius="17dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

        </LinearLayout>

        <!-- Thin divider under header -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/colorDivider" />

        <!-- ── Messages (full remaining height) ───────────────────── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="6dp" />

        <!-- ── Image preview strip (GONE by default) ─────────────── -->
        <LinearLayout
            android:id="@+id/imagePreviewStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imagePreviewThumbnail"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_chapter_number"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/imagePreviewLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Image attached"
                android:textColor="@color/colorTextPrimary"
                android:textSize="13sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/removeImageButton"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="✕"
                android:textSize="13sp"
                android:textColor="@color/colorError"
                app:backgroundTint="@color/colorErrorLight"
                app:cornerRadius="16dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <!-- ── AI loading indicator (GONE by default) ────────────── -->
        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/colorPrimaryLight"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:indeterminateTint="@color/colorPrimary"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI is thinking..."
                android:textColor="@color/colorPrimary"
                android:textSize="13sp"
                android:textStyle="italic" />

        </LinearLayout>

        <!-- ── Bottom area (white card with elevation) ───────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="6dp">

            <!-- Voice chat bar (GONE – shown in voice mode) -->
            <LinearLayout
                android:id="@+id/voiceChatBar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/colorPrimary"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/waveBarContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="10dp">

                    <View android:id="@+id/waveBar1" android:layout_width="3dp" android:layout_height="10dp" android:background="#FFFFFF" android:layout_marginEnd="2dp" />
                    <View android:id="@+id/waveBar2" android:layout_width="3dp" android:layout_height="18dp" android:background="#FFFFFF" android:layout_marginEnd="2dp" />
                    <View android:id="@+id/waveBar3" android:layout_width="3dp" android:layout_height="14dp" android:background="#FFFFFF" android:layout_marginEnd="2dp" />
                    <View android:id="@+id/waveBar4" android:layout_width="3dp" android:layout_height="8dp" android:background="#FFFFFF" />

                </LinearLayout>

                <TextView
                    android:id="@+id/voiceChatStatus"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Listening..."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/voiceModeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LIVE"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:background="@drawable/bg_badge_rounded" />

            </LinearLayout>

            <!-- Listening indicator (GONE by default) -->
            <TextView
                android:id="@+id/listeningIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Listening... speak now"
                android:textSize="12sp"
                android:textColor="@color/colorError"
                android:textStyle="italic"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="4dp"
                android:visibility="gone" />

            <!-- ═══════════════════════════════════════════════════════
                 QUICK ACTIONS PANEL — GONE by default, toggled by (+)
                 ═══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/quickActionsPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <!-- Top divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider"
                    android:layout_marginBottom="10dp" />

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI ACTIONS"
                    android:textSize="10sp"
                    android:textColor="@color/colorTextHint"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <!-- Row 1: Explain, Quiz, Formulas, Practice -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="6dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/explainButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="💡 Explain"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorPrimaryLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/quizButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="🎯 Quiz"
                        android:textColor="@color/colorSuccess"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorSuccessLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/formulaButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="∑ Formula"
                        android:textColor="@color/colorError"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorErrorLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/practiceButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="✏️ Practice"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorPrimaryLight"
                        app:cornerRadius="18dp" />

                </LinearLayout>

                <!-- Row 2: Flashcards, Notes, Save Notes, View Notes -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/flashcardsButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="🃏 Cards"
                        android:textColor="@color/colorError"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorErrorLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/notesButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="📝 Notes"
                        android:textColor="@color/colorSuccess"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorSuccessLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveNotesButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="💾 Save"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorPrimaryLight"
                        app:cornerRadius="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/viewNotesButton"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="👁 View"
                        android:textColor="@color/colorPrimary"
                        android:textSize="11sp"
                        app:backgroundTint="@color/colorPrimaryLight"
                        app:cornerRadius="18dp" />

                </LinearLayout>

                <!-- Section label 2 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TOOLS"
                    android:textSize="10sp"
                    android:textColor="@color/colorTextHint"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="6dp" />

                <!-- Row 3: Tool icon buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <!-- Image picker -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/imageButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:padding="0dp"
                        android:text="📷 Image"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="@color/colorBackground"
                        app:strokeColor="@color/colorDivider"
                        app:strokeWidth="1dp"
                        app:cornerRadius="18dp" />

                    <!-- Blackboard / Auto-Explain -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/autoExplainButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:padding="0dp"
                        android:text="📋 Board"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="@color/colorPrimary"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="@color/colorPrimaryLight"
                        app:strokeWidth="0dp"
                        app:cornerRadius="18dp" />

                    <!-- Live voice chat -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/voiceChatButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:padding="0dp"
                        android:text="🎙 Live"
                        android:textSize="11sp"
                        android:textColor="@color/colorError"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        app:backgroundTint="@color/colorErrorLight"
                        app:strokeWidth="0dp"
                        app:cornerRadius="18dp" />

                    <!-- Clear chat -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/clearChatButton"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="🗑 Clear"
                        android:textSize="11sp"
                        android:textColor="@color/colorTextSecondary"
                        app:backgroundTint="@color/colorBackground"
                        app:strokeColor="@color/colorDivider"
                        app:strokeWidth="1dp"
                        app:cornerRadius="18dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />

                </LinearLayout>

                <!-- Hidden: bottomDescribeButton (shown when image picked) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/bottomDescribeButton"
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:minHeight="0dp"
                    android:text="🔍 Describe this image"
                    android:textSize="12sp"
                    android:textColor="@color/colorPrimary"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    app:backgroundTint="@color/colorPrimaryLight"
                    app:strokeWidth="0dp"
                    app:cornerRadius="18dp"
                    android:layout_marginTop="6dp"
                    android:visibility="gone" />

                <!-- Hidden utility elements (code-only, not visible) -->
                <TextView
                    android:id="@+id/liveModeChip"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:text="Live"
                    android:visibility="gone" />

            </LinearLayout>
            <!-- END quickActionsPanel -->

            <!-- ── Input row ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <!-- Plus button (toggle quick actions) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/plusButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="0dp"
                    android:text="+"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorPrimaryLight"
                    app:cornerRadius="21dp"
                    android:layout_marginEnd="8dp" />

                <!-- Message input -->
                <EditText
                    android:id="@+id/messageInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Message AI Guru..."
                    android:minLines="1"
                    android:maxLines="5"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextHint"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="flagNoEnterAction" />

                <!-- Mic button (beside send) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/voiceButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="0dp"
                    android:text="🎤"
                    android:textSize="17sp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorBackground"
                    app:strokeColor="@color/colorDivider"
                    app:strokeWidth="1dp"
                    app:cornerRadius="21dp"
                    android:layout_marginStart="6dp" />

                <!-- Send button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:padding="0dp"
                    android:text="➤"
                    android:textSize="17sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="6dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    app:backgroundTint="@color/colorPrimary"
                    app:cornerRadius="21dp" />

            </LinearLayout>

        </LinearLayout>
        <!-- END bottom area -->

    </LinearLayout>
    <!-- END main content -->

    <!-- ── Pages drawer ──────────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/pagesDrawerPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="10dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/pagesDrawerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chapter Pages"
                android:textColor="@color/colorTextPrimary"
                android:textStyle="bold"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pagesDrawerCloseButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:text="✕"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                app:backgroundTint="@color/colorBackground"
                app:cornerRadius="17dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pagesDrawerAddPageButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="+ Add Page"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="12dp" />

        <TextView
            android:id="@+id/pagesDrawerHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            android:text="Select a page to preview or ask AI"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pagesDrawerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>

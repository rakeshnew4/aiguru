<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/chatDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ChatActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <LinearLayout
            android:id="@+id/chatHeaderRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/chapterIconBadge"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="8dp"
                android:gravity="center"
                android:text="📘"
                android:textSize="16sp"
                android:background="@drawable/rounded_edittext_bg" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/chatHeaderTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chapter Session"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/chatHeaderSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="AI Tutor"
                    android:textColor="#6B7280"
                    android:textSize="11sp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openPagesDrawerButton"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:minHeight="0dp"
                android:text="Pages"
                android:textAllCaps="false"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                app:backgroundTint="#111827"
                app:strokeColor="#111827"
                app:strokeWidth="1dp"
                app:cornerRadius="19dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#ECEFF3" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center_vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/explainButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Explain"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/quizButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Quiz Me"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/formulaButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Formulas"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/practiceButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Practice"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/notesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Notes"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/saveNotesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Save Notes"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/viewNotesButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="View Notes"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp"
                    android:layout_marginEnd="6dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/flashcardsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Flashcards"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    app:backgroundTint="#EEF2FF"
                    app:cornerRadius="18dp" />

            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/messagesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:clipToPadding="false"
            android:paddingStart="6dp"
            android:paddingTop="8dp"
            android:paddingEnd="6dp"
            android:paddingBottom="8dp"
            tools:listitem="@android:layout/simple_list_item_1" />

        <LinearLayout
            android:id="@+id/imagePreviewStrip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F9FAFB"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ImageView
                android:id="@+id/imagePreviewThumbnail"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:layout_marginEnd="10dp"
                android:contentDescription="Image preview" />

            <TextView
                android:id="@+id/imagePreviewLabel"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Image selected — ask anything"
                android:textSize="13sp"
                android:textColor="#374151" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/removeImageButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="0dp"
                android:text="X"
                android:textSize="14sp"
                android:textColor="#9CA3AF"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/loadingLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:text="AI"
                android:textSize="9sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginEnd="10dp" />

            <ProgressBar
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:indeterminateTint="#9CA3AF"
                android:layout_marginEnd="8dp"
                style="@style/Widget.AppCompat.ProgressBar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thinking..."
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="#9CA3AF" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E5E7EB" />

            <LinearLayout
                android:id="@+id/voiceChatBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#FAFAFA"
                android:paddingStart="14dp"
                android:paddingEnd="10dp"
                android:paddingTop="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/waveBarContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="8dp"
                    android:clipChildren="false"
                    android:visibility="gone">

                    <View
                        android:id="@+id/waveBar1"
                        android:layout_width="3dp"
                        android:layout_height="8dp"
                        android:background="#1565C0"
                        android:layout_marginEnd="3dp" />

                    <View
                        android:id="@+id/waveBar2"
                        android:layout_width="3dp"
                        android:layout_height="16dp"
                        android:background="#1565C0"
                        android:layout_marginEnd="3dp" />

                    <View
                        android:id="@+id/waveBar3"
                        android:layout_width="3dp"
                        android:layout_height="12dp"
                        android:background="#1565C0"
                        android:layout_marginEnd="3dp" />

                    <View
                        android:id="@+id/waveBar4"
                        android:layout_width="3dp"
                        android:layout_height="6dp"
                        android:background="#1565C0" />

                </LinearLayout>

                <TextView
                    android:id="@+id/voiceChatStatus"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Listening..."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#111827" />

                <TextView
                    android:id="@+id/voiceModeBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARTIAL"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#0B4AA2"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:background="@drawable/rounded_edittext_bg" />

            </LinearLayout>

            <TextView
                android:id="@+id/listeningIndicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Listening... speak now"
                android:textSize="12sp"
                android:textColor="#DC2626"
                android:textStyle="italic"
                android:gravity="center"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:visibility="gone" />

            <HorizontalScrollView
                android:id="@+id/bottomQuickActionsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/bottomDescribeButton"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:minHeight="0dp"
                        android:text="Describe Image"
                        android:textSize="11sp"
                        android:textColor="#374151"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        app:strokeColor="#E5E7EB"
                        app:cornerRadius="15dp"
                        app:backgroundTint="#00000000"
                        android:visibility="gone" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/imageButton"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="0dp"
                        android:text="&#128247;"
                        android:layout_marginStart="10dp"
                        android:textSize="18sp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/autoExplainButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="0dp"
                        android:text="BB"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="#7C2D12"
                        app:backgroundTint="#FFEDD5"
                        app:cornerRadius="22dp"
                        app:rippleColor="#22000000"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/voiceButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="0dp"
                        android:text="&#127908;"
                        android:textSize="19sp"
                        app:backgroundTint="#EAF2FF"
                        app:cornerRadius="22dp"
                        android:layout_marginStart="4dp"
                        style="@style/Animation.Design.BottomSheetDialog" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/languageButton"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:layout_marginStart="8dp"
                        android:minHeight="0dp"
                        android:text="Language ▾"
                        android:textAllCaps="false"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0B4AA2"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        app:backgroundTint="#EAF2FF"
                        app:strokeColor="#BFD7FF"
                        app:strokeWidth="1dp"
                        app:cornerRadius="17dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/voiceChatButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:padding="0dp"
                        android:text="&#127897;"
                        android:textSize="19sp"
                        app:backgroundTint="#F3F4F6"
                        app:cornerRadius="22dp"
                        android:layout_marginStart="4dp" />

                    <TextView
                        android:id="@+id/liveModeChip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Live"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#0B4AA2"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:background="@drawable/rounded_edittext_bg" />

                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="10dp">

                <EditText
                    android:id="@+id/messageInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Message AI Guru..."
                    android:minLines="1"
                    android:maxLines="5"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="10dp"
                    android:textSize="15sp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="flagNoEnterAction" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sendButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="0dp"
                    android:text="&#10148;"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="4dp"
                    app:backgroundTint="#1565C0"
                    app:cornerRadius="22dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/pagesDrawerPanel"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="10dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/pagesDrawerTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chapter Pages"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pagesDrawerCloseButton"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:minHeight="0dp"
                android:text="X"
                android:textSize="12sp"
                android:textColor="#6B7280"
                app:backgroundTint="#F3F4F6"
                app:cornerRadius="17dp"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/pagesDrawerAddPageButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:text="Add Page"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            app:backgroundTint="#1565C0"
            app:cornerRadius="10dp" />

        <TextView
            android:id="@+id/pagesDrawerHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            android:text="Select a page to preview or ask AI"
            android:textColor="#6B7280"
            android:textSize="12sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/pagesDrawerList"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>

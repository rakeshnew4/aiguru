<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="16dp"
    app:cardBackgroundColor="#1A1F3C">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Step counter -->
        <TextView
            android:id="@+id/tourStepCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 8"
            android:textSize="11sp"
            android:textColor="#7B8DB0"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp" />

        <!-- Feature title -->
        <TextView
            android:id="@+id/tourTitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp" />

        <!-- Description -->
        <TextView
            android:id="@+id/tourDescText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#B0BFDD"
            android:lineSpacingMultiplier="1.45"
            android:layout_marginBottom="20dp" />

        <!-- Action row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Skip -->
            <TextView
                android:id="@+id/tourSkipBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Skip tour"
                android:textSize="13sp"
                android:textColor="#7B8DB0"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Next / Finish -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/tourNextBtn"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Next →"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                app:backgroundTint="#3D5AFE"
                app:cornerRadius="20dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

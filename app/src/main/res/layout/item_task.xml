<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="8dp"
    android:padding="14dp"
    android:elevation="1dp">

    <!-- Top row: badge + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/taskTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="11sp"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Completed badge (shown when done) -->
        <TextView
            android:id="@+id/completedBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅ Done"
            android:textSize="12sp"
            android:textColor="#2E7D32"
            android:visibility="gone" />

    </LinearLayout>

    <TextView
        android:id="@+id/taskDesc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/colorTextSecondary"
        android:textSize="12sp"
        android:maxLines="2"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/taskMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="#5C5BD4"
        android:textSize="12sp" />

    <!-- Action buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewLessonBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🎓 View Lesson"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginEnd="6dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/takeQuizBtn"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="🧠 Take Quiz"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/markDoneBtn"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Mark Done"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginStart="6dp"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        app:title="Model Settings"
        app:titleTextColor="#111827"
        app:navigationIcon="@drawable/ic_arrow_back"
        android:elevation="0dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8EAED" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- ── Backend Provider ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Backend Provider"
                android:textSize="11sp"
                android:textColor="#6B7280"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="10dp" />

            <RadioGroup
                android:id="@+id/providerRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <RadioButton
                    android:id="@+id/radioGroq"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Groq (Built-in)"
                    android:textSize="15sp"
                    android:textColor="#111827"
                    android:background="@drawable/bg_ai_bubble"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp"
                    android:button="@null"
                    android:drawableEnd="@null" />

                <RadioButton
                    android:id="@+id/radioServer"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Server Proxy (Custom URL)"
                    android:textSize="15sp"
                    android:textColor="#111827"
                    android:background="@drawable/bg_ai_bubble"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:gravity="center_vertical"
                    android:button="@null" />

            </RadioGroup>

            <!-- ── Groq Configuration ──────────────────────────────── -->
            <LinearLayout
                android:id="@+id/groqSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Groq Configuration"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text model"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/textModelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vision model"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/visionModelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />

            </LinearLayout>

            <!-- ── Server Proxy Configuration ─────────────────────── -->
            <LinearLayout
                android:id="@+id/serverSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server Configuration"
                    android:textSize="11sp"
                    android:textColor="#6B7280"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Server URL"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/serverUrlInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:hint="https://my-server.com"
                    android:inputType="textUri"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Model name"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/serverModelInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:hint="e.g. llama3, gpt-4o, mistral"
                    android:inputType="text"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="API key (optional)"
                    android:textSize="13sp"
                    android:textColor="#374151"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/serverApiKeyInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/rounded_edittext_bg"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:textColor="#111827"
                    android:textColorHint="#9CA3AF"
                    android:hint="sk-..."
                    android:inputType="textPassword" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="The server must expose an OpenAI-compatible /v1/chat/completions endpoint with SSE streaming support."
                    android:textSize="12sp"
                    android:textColor="#9CA3AF"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- ── Save ────────────────────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save"
                android:textSize="15sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="#1565C0"
                app:cornerRadius="12dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
  bottom_sheet_feedback.xml
  Feedback bottom sheet shown after the user's first Blackboard session.
  Collects a 1-5 star rating and an optional suggestion text.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorSurface"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="#CCCCCC" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:text="How was your session? ⭐"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextPrimary" />

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="6dp"
        android:paddingBottom="20dp"
        android:text="Your feedback helps us improve AI Guru for everyone."
        android:textSize="14sp"
        android:textColor="@color/colorTextSecondary"
        android:lineSpacingMultiplier="1.3" />

    <!-- Star rating row -->
    <LinearLayout
        android:id="@+id/starRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/star1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="32sp"
            android:textColor="#FFC107" />

        <TextView
            android:id="@+id/star2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="32sp"
            android:textColor="#FFC107" />

        <TextView
            android:id="@+id/star3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="32sp"
            android:textColor="#FFC107" />

        <TextView
            android:id="@+id/star4"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="32sp"
            android:textColor="#FFC107" />

        <TextView
            android:id="@+id/star5"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="☆"
            android:textSize="32sp"
            android:textColor="#FFC107" />
    </LinearLayout>

    <!-- Suggestion text input -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/feedbackText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="What can we improve? (optional)"
            android:inputType="textMultiLine|textCapSentences"
            android:minLines="3"
            android:maxLines="6"
            android:gravity="top|start"
            android:textColor="@color/colorTextPrimary"
            android:textColorHint="@color/colorTextSecondary" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSkipFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maybe later"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitFeedback"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit"
            android:backgroundTint="@color/colorPrimary" />
    </LinearLayout>

</LinearLayout>

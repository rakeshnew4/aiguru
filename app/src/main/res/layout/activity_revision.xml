<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F1724"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@null"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🃏 Revision Cards"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/cardCountText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Card 1 of 5"
                android:textColor="#8899AA"
                android:textSize="13sp" />

        </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#40E0D0" />


    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:progressTint="#FF8F00"
        android:progressBackgroundTint="#C5CAE9"
        android:progress="20"
        android:max="100" />

    <!-- Flashcard area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/flashcard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="28dp"
                android:background="#161D2A">

                <!-- QUESTION / ANSWER pill label -->
                <TextView
                    android:id="@+id/cardLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUESTION"
                    android:textSize="11sp"
                    android:textColor="#8899AA"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:background="@drawable/bg_flash_pill"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginBottom="20dp" />

                <!-- Card text -->
                <TextView
                    android:id="@+id/cardText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="What is photosynthesis?"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:lineSpacingExtra="4dp" />

                <!-- Tap hint -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👆 Tap card to reveal answer"
                    android:textSize="12sp"
                    android:textColor="#8899AA"
                    android:layout_marginTop="32dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <!-- Navigation buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/prevButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="← Prev"
            android:textColor="#40E0D0"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#40E0D0"
            app:cornerRadius="12dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Next →"
            android:textColor="#FFFFFF"
            app:backgroundTint="#40E0D0"
            app:cornerRadius="12dp"
            android:layout_marginStart="8dp" />

    </LinearLayout>

</LinearLayout>

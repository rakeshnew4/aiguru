<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Badge + Plan Name Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/planName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Basic"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E" />

                <TextView
                    android:id="@+id/planDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="per month"
                    android:textSize="12sp"
                    android:textColor="#546E7A"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Badge -->
            <TextView
                android:id="@+id/planBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Popular"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_badge_rounded"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Price -->
        <TextView
            android:id="@+id/planPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="₹99"
            android:textSize="36sp"
            android:textStyle="bold"
            android:textColor="#1565C0" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="#E0E0E0" />

        <!-- Features list -->
        <TextView
            android:id="@+id/planFeatures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Feature 1\n• Feature 2"
            android:textSize="14sp"
            android:textColor="#37474F"
            android:lineSpacingMultiplier="1.5" />

        <!-- CTA Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/selectPlanButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="18dp"
            android:text="Get Started →"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1565C0"
            app:cornerRadius="10dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>

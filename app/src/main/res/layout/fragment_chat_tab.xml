<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBackground">

    <!-- "Open Full Chat" shortcut — gives access to voice, images, quiz, blackboard, etc. -->

    <!-- Message list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatMessagesRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false" />

    <!-- Streaming / loading indicator -->
    <TextView
        android:id="@+id/chatLoadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="AI is thinking…"
        android:textSize="12sp"
        android:textColor="@color/colorPrimary"
        android:paddingTop="4dp"
        android:paddingBottom="2dp"
        android:visibility="gone" />

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:elevation="4dp">

        <EditText
            android:id="@+id/chatInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Ask anything about this chapter…"
            android:textSize="14sp"
            android:maxLines="4"
            android:inputType="textMultiLine|textCapSentences"
            android:background="@drawable/rounded_edittext_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/chatSendButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="➤"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="24dp" />

    </LinearLayout>

</LinearLayout>

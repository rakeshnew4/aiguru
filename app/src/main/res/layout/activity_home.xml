<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/homeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning"
                android:textSize="12sp"
                android:textColor="@color/colorTextSecondary" />

            <TextView
                android:id="@+id/userNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍🎤  Student"
                android:textSize="21sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/schoolNameSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="School"
                android:textSize="11sp"
                android:textColor="@color/colorTextSecondary"
                android:layout_marginTop="1dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/planBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRO"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_rounded"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/profileButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="👨‍🎤"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_avatar_circle" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">



            <com.google.android.material.button.MaterialButton
                android:id="@+id/libraryButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="Library"
                android:textSize="13sp"
                android:textColor="@color/colorError"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorErrorLight"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/progressButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Progress"
                android:textSize="13sp"
                android:textColor="@color/colorSuccess"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorSuccessLight"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/colorBackground">

        <!-- ── Offers / Announcements banner ──────────────────────────── -->
        <HorizontalScrollView
            android:id="@+id/offersBannerScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/offersBannerContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Sample offer card 1 -->
                <com.google.android.material.card.MaterialCardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="260dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/colorPrimary">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:text="🎓 New Chapters Added!\nMaths &amp; Science — Class 9"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="36sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sample offer card 2 -->
                <com.google.android.material.card.MaterialCardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="240dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="10dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="#1565C0">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⚡ Live Doubt Solving\nAsk AI Guru anything!"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖"
                            android:textSize="36sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Sample offer card 3 -->
                <com.google.android.material.card.MaterialCardView
                    xmlns:app="http://schemas.android.com/apk/res-auto"
                    android:layout_width="240dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="3dp"
                    app:cardBackgroundColor="@color/colorSuccess">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📝 Practice Mode\nFlashcards &amp; Quizzes ready"
                            android:textColor="#FFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="2dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🃏"
                            android:textSize="36sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </HorizontalScrollView>

        <!-- ── "My Subjects" header ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Subjects"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/subjectCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subjectsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:background="#FFFFFF"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">




    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generalChatButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text=" 🤖 Quick Chat"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/practice_pink"
            app:cornerRadius="22dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="80dp"
            />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addSubjectButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="+ Add Subject"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="22dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</LinearLayout>

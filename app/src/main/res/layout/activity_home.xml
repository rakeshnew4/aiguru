<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent">

    <!-- 🔥 Background gradient -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/ssw"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ✅ ADVANCED HEADER (WITH ALL FEATURES) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#00776B"
            app:strokeColor="#3340E0D0"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/homeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/greetingText"
                        android:text="Hey! ☀️"
                        android:textColor="#40E0D0"
                        android:textSize="12sp"
                        android:letterSpacing="0.06"
                         android:layout_height="30dp"
                        android:layout_width="100dp"/>

                    <TextView
                        android:id="@+id/userNameText"
                        android:text="Student"
                        android:textColor="#FFFFFF"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_height="30dp"
                        android:layout_width="300dp"/>

                    <TextView
                        android:id="@+id/schoolNameSubtitle"
                        android:text=""
                        android:textColor="#80B8C8"
                        android:textSize="11sp"
                        android:layout_height="30dp"
                        android:layout_width="100dp"/>
                </LinearLayout>

                <!-- RIGHT (PLAN BADGE + PROFILE) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/planBadgeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRO"
                        android:textColor="#000000"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_badge_rounded"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:layout_marginEnd="10dp"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/profileButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:gravity="center"
                        android:text="👤"
                        android:textSize="18sp"
                        android:background="@drawable/bg_avatar_circle"/>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ✅ SUBJECT HEADER (WITH COUNT) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🎒 My Subjects"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <TextView
                android:id="@+id/subjectCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 subjects"
                android:textSize="12sp"
                android:textColor="#40E0D0"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"/>
        </LinearLayout>

        <!-- ✅ SUBJECT GRID -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subjectsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"/>

        <!-- ✅ GENERAL CHAT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/generalChatButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="8dp"
            android:text="💬 General Chat"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:backgroundTint="#1B2A3A"
            app:cornerRadius="18dp"
            app:strokeColor="#40E0D0"
            app:strokeWidth="1.5dp"/>

        <!-- ✅ BOTTOM ACTION BUTTONS (ALL PRESERVED) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:paddingBottom="28dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/libraryButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="📖 Library"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:backgroundTint="#FFE040"/>

            <Space android:layout_width="8dp" android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/progressButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Progress"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:backgroundTint="#00796B"/>

            <Space android:layout_width="8dp" android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addSubjectButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="+ Add"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                app:cornerRadius="18dp"
                app:backgroundTint="#1A1A2E"
                app:strokeColor="#40E0D0"
                app:strokeWidth="1.5dp"/>
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/homeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="2dp">


        <LinearLayout
            android:layout_width="161dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/userNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍🎤  Student"
                android:textColor="@color/colorTextPrimary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/schoolNameSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="School"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/planBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRO"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_rounded"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <!-- School logo — shown only when school has a logoUrl; hidden otherwise -->
        <ImageView
            android:id="@+id/schoolLogoImage"
            android:layout_width="150dp"
            android:layout_height="16dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="School logo"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/profileButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="👨‍🎤"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_avatar_circle" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">



            <com.google.android.material.button.MaterialButton
                android:id="@+id/libraryButton"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:text="Library"
                android:textSize="13sp"
                android:textColor="@color/colorError"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorErrorLight"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/progressButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Progress"
                android:textSize="13sp"
                android:textColor="@color/colorSuccess"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorSuccessLight"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/langChipButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🌐 English"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorBackground"
                app:strokeColor="@color/colorDivider"
                app:strokeWidth="1dp"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/colorBackground">

        <!-- ── Offers / Announcements banner ──────────────────────────── -->
        <LinearLayout
            android:id="@+id/offersSectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔥 Special Offers"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A237E" />

            <TextView
                android:id="@+id/offersLiveIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#E53935"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/offersBannerScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/offersBannerContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── Daily quota strip ────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/quotaStripCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#F0F4FF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:visibility="gone">

            <!-- Chat questions left -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/quotaChatCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💬 Chat left today"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/colorDivider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Blackboard sessions left -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/quotaBbCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎓 Blackboard left"
                    android:textSize="11sp"
                    android:textColor="@color/colorTextSecondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── "My Subjects" header ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Subjects"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/subjectCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />

        </LinearLayout>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/homeSwipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/subjectsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="#FFFFFF"
                android:paddingBottom="8dp"
                android:clipToPadding="false" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">




    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/generalChatButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text=" 🤖 Quick Chat"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/practice_pink"
            app:cornerRadius="22dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginStart="1dp"
            android:layout_marginEnd="80dp"
            />
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addSubjectButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="+ Add Subject"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:minWidth="0dp"
            android:minHeight="0dp"
            app:backgroundTint="@color/colorPrimary"
            app:cornerRadius="22dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</LinearLayout>

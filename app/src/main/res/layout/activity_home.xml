<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/homeDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

<!-- ═══════════════════════  MAIN CONTENT  ═══════════════════════ -->
<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:orientation="vertical"
    android:background="@color/colorBackground"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/homeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:elevation="2dp">

        <!-- Hamburger — opens the left navigation drawer -->
        <TextView
            android:id="@+id/drawerToggleBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="☰"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:layout_marginEnd="4dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning"
                android:textColor="@color/colorTextSecondary"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/userNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍🎤  Student"
                android:textColor="@color/colorTextPrimary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/schoolNameSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:text="School"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp" />

        </LinearLayout>

        <TextView
            android:id="@+id/planBadgeText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRO"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_rounded"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="10dp"
            android:visibility="gone" />

        <!-- School logo — shown only when school has a logoUrl; hidden otherwise -->
        <ImageView
            android:id="@+id/schoolLogoImage"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="0.4"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="School logo"
            android:scaleType="centerCrop"
            android:visibility="gone" />

        <TextView
            android:id="@+id/profileButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:gravity="center"
            android:text="👨‍🎤"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_avatar_circle" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingTop="10dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">



            <com.google.android.material.button.MaterialButton
                android:id="@+id/langChipButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="🌐 English"
                android:textAllCaps="false"
                android:textSize="13sp"
                android:textColor="@color/colorTextSecondary"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorBackground"
                app:strokeColor="@color/colorDivider"
                app:strokeWidth="1dp"
                app:cornerRadius="18dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginEnd="8dp" />

        </LinearLayout>

    </HorizontalScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/colorBackground">

        <!-- ── Offers / Announcements banner ──────────────────────────── -->
        <LinearLayout
            android:id="@+id/offersSectionHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="2dp"
            android:visibility="gone">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🔥 Special Offers"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1A237E" />

            <TextView
                android:id="@+id/offersLiveIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● LIVE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#E53935"
                android:background="@android:color/transparent" />

        </LinearLayout>

        <HorizontalScrollView
            android:id="@+id/offersBannerScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/offersBannerContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── "My Subjects" header ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My Subjects"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextPrimary" />

            <TextView
                android:id="@+id/subjectCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:layout_marginEnd="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/addSubjectButton"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:text="+ Add"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:minWidth="0dp"
                android:minHeight="0dp"
                app:backgroundTint="@color/colorPrimary"
                app:cornerRadius="17dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>


        
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/homeSwipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/subjectsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:background="#FFFFFF"
                android:paddingBottom="8dp"
                android:clipToPadding="false" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
        <!-- ── Quick Chat button (bottom) ──────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                app:rippleColor="#33FFFFFF"
                app:cardCornerRadius="28dp"
                app:cardElevation="10dp"
                app:cardBackgroundColor="#1A1A2E">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/generalChatButton"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="✨ Quick Chat - AI Lessons (BB)"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@android:color/transparent"
                    android:gravity="center" />

            </com.google.android.material.card.MaterialCardView>

        </FrameLayout>

    </LinearLayout>
    <!-- end layout_weight=1 content area -->

</LinearLayout>
<!-- end main content -->

<!-- ═══════════════════════  LEFT NAV DRAWER  ═══════════════════════ -->
<LinearLayout
    android:id="@+id/navDrawer"
    android:layout_width="288dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:orientation="vertical"
    android:background="@color/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Drawer header -->
    <LinearLayout
        android:id="@+id/drawerHeaderCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/colorPrimary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <TextView
            android:id="@+id/drawerAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="👨‍🎤"
            android:textSize="28sp"
            android:background="@drawable/bg_avatar_circle"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/drawerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/drawerSchool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="School"
            android:textColor="#FFFFFFBB"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/drawerPlanBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Free"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:background="@drawable/bg_badge_rounded"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Usage section label -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TODAY'S USAGE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/colorTextSecondary"
                android:letterSpacing="0.12"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp" />

            <!-- Chat usage row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="💬 Chat questions"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/drawerChatLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorSecondary" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/drawerChatProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progressTint="@color/colorSecondary"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

            <!-- Blackboard usage row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎓 Blackboard sessions"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/drawerBbLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#7B1FA2" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/drawerBbProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progressTint="#7B1FA2"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

            <!-- AI Voice credits row -->
            <LinearLayout
                android:id="@+id/drawerVoiceRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎙 AI voice credits"
                        android:textSize="13sp"
                        android:textColor="@color/colorTextPrimary" />

                    <TextView
                        android:id="@+id/drawerVoiceLeft"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorSuccess" />

                </LinearLayout>

                <ProgressBar
                    android:id="@+id/drawerVoiceProgress"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:progressTint="@color/colorSuccess"
                    android:progressBackgroundTint="@color/colorDivider"
                    android:max="100"
                    android:progress="0" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/colorDivider"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp" />

            <!-- Nav items -->
            <LinearLayout
                android:id="@+id/drawerItemProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Profile"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerItemProgress"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="📈"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Progress"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerItemTeacher"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="👩‍🏫"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Teacher Dashboard"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerItemTasks"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tasks"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerItemJoinSchool"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="🏫"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Join / Switch School"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerItemPlans"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:text="💳"
                    android:textSize="18sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Plans &amp; Payments"
                    android:textSize="15sp"
                    android:textColor="@color/colorTextPrimary"
                    android:paddingStart="12dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Drawer footer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider" />

    <LinearLayout
        android:id="@+id/drawerItemSignOut"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text="🚪"
            android:textSize="18sp"
            android:gravity="center" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sign Out"
            android:textSize="15sp"
            android:textColor="@color/colorError"
            android:paddingStart="12dp" />

    </LinearLayout>

</LinearLayout>
<!-- end drawer -->

</androidx.drawerlayout.widget.DrawerLayout>

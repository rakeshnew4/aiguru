<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blackboard"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════════════════════════════════
         LOADING STATE
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <com.aiguruapp.student.widget.BoxSpinnerView
            android:id="@+id/boxSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preparing lesson..."
            android:textColor="#B0C8E8"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         CONTENT
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── TOP BAR (fully transparent, 0dp height — replaced by floating controls) ── -->
        <!-- stepCounter kept in hierarchy (hidden) so Kotlin references still compile -->
        <TextView
            android:id="@+id/stepCounter"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ── LESSON CONTENT ─────────────────────────────────────────────── -->
        <ScrollView
            android:id="@+id/stepsScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- ── DOT INDICATORS ────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- ── PROGRESS HINT ("Almost done!") ────────────────────────────── -->
        <TextView
            android:id="@+id/bbProgressHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="🔥 Almost done!"
            android:textColor="#FACC15"
            android:textSize="12sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <!-- ── MEDIA CONTROLS ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC0D1033"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <!-- Thin non-interactive progress strip -->
            <ProgressBar
                android:id="@+id/bbProgressSeek"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#3D5AFE"
                android:progressBackgroundTint="#1E2A50" />

            <!-- Transport row: ⬅ Prev | 🔁 Replay | ▶/⏸ Play | ➡ Next | TTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <!-- Prev step -->
                <TextView
                    android:id="@+id/prevButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="⬅"
                    android:textSize="18sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Replay -->
                <TextView
                    android:id="@+id/replayButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="↺"
                    android:textSize="19sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Play / Pause (primary, larger) -->
                <TextView
                    android:id="@+id/pauseButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="⏸"
                    android:textSize="22sp"
                    android:textColor="#3D5AFE"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Next step -->
                <TextView
                    android:id="@+id/nextButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="➡"
                    android:textSize="18sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/aiTtsToggleBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:gravity="center"
                    android:text="🔊 TTS"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="#7A9ABB"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:background="@drawable/bg_tts_pill"
                    android:minWidth="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── HAND WRITER INDICATOR ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/handWriter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✍🏽"
        android:textSize="28sp"
        android:visibility="invisible" />

    <!-- ── TOP-LEFT: Sessions left chip ─────────────────────────────────── -->
    <TextView
        android:id="@+id/bbQuotaChip"
        android:layout_width="wrap_content"
        android:layout_height="28dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="14dp"
        android:layout_marginTop="44dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:textSize="11sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_chip_indigo"
        android:visibility="gone"
        android:gravity="center"
        android:text="" />

    <!-- ── TOP-RIGHT: Save + Publish + Close cluster ─────────────────────── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/saveSessionBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="💾"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

        <TextView
            android:id="@+id/publishLessonBtn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="📤"
            android:textSize="16sp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:visibility="gone" />

        <TextView
            android:id="@+id/closeButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✕"
            android:textColor="#9ABBD8"
            android:textSize="17sp"
            android:background="?attr/selectableItemBackgroundBorderless" />

    </LinearLayout>

    <!-- ── SUBTITLE OVERLAY (shown while TTS speaks) ───────────────────── -->
    <!-- Sits low, just above the media controls — doesn't cover board text -->
    <TextView
        android:id="@+id/bbSubtitleTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="72dp"
        android:background="@android:color/transparent"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:maxLines="3"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="9dp"
        android:paddingBottom="9dp"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- ── FLOATING CHAT FAB (bottom-right, always visible) ─────────────── -->
    <TextView
        android:id="@+id/bbChatFab"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="90dp"
        android:gravity="center"
        android:text="💬"
        android:textSize="22sp"
        android:background="@drawable/bg_send_circle"
        android:elevation="8dp" />

    <!-- ── ASK BAR OVERLAY (slides up from bottom when FAB tapped) ──────── -->
    <LinearLayout
        android:id="@+id/bbAskBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#F2101828"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:paddingTop="8dp"
        android:elevation="10dp"
        android:visibility="gone">

        <!-- Dismiss handle + label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ask about this lesson"
                android:textColor="#5A7A9A"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/bbAskToggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="14sp"
                android:textColor="#5A7A9A"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- Image preview strip -->
        <LinearLayout
            android:id="@+id/bbImgPreviewRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/bbImgPreviewThumb"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_thumb_rounded"
                android:clipToOutline="true"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/bbImgPreviewLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Image attached"
                android:textColor="#8AABCC"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/bbImgPreviewRemove"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="13sp"
                android:textColor="#FF7070"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- Input pill row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_ask_pill"
            android:paddingStart="6dp"
            android:paddingEnd="6dp">

            <TextView
                android:id="@+id/bbCameraBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📷"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <EditText
                android:id="@+id/bbAskInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Ask about this lesson…"
                android:textColor="#EEF0FF"
                android:textColorHint="#4A5880"
                android:textSize="13sp"
                android:background="@null"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:imeOptions="actionSend"
                android:inputType="textCapSentences"
                android:maxLines="3" />

            <TextView
                android:id="@+id/bbMicBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🎤"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/bbAskSend"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="↑"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:layout_marginStart="2dp"
                android:background="@drawable/bg_send_circle" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>

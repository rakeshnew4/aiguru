<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blackboard"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════════════════════════════════
         LOADING STATE
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <com.aiguruapp.student.widget.BoxSpinnerView
            android:id="@+id/boxSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preparing lesson..."
            android:textColor="#B0C8E8"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         CONTENT
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── TOP BAR ────────────────────────────────────────────────────── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#CC0D1033"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:elevation="6dp">

            <!-- Quota chip (left) -->
            <TextView
                android:id="@+id/bbQuotaChip"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_chip_indigo"
                android:visibility="gone"
                android:gravity="center"
                android:text="" />

            <!-- Step counter (centre) -->
            <TextView
                android:id="@+id/stepCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Step 1 / 5"
                android:textColor="#E0ECF8"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <!-- Save + Publish + Close (right cluster) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/saveSessionBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="💾"
                    android:textSize="16sp"
                    android:paddingStart="8dp"
                    android:paddingEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/publishLessonBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:gravity="center"
                    android:text="📤"
                    android:textSize="16sp"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/closeButton"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="4dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textColor="#7A9ABB"
                    android:textSize="16sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Thin accent progress bar under the top bar -->
        <View
            android:id="@+id/topAccentLine"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#3D5AFE" />

        <!-- ── LESSON CONTENT ─────────────────────────────────────────────── -->
        <ScrollView
            android:id="@+id/stepsScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- ── DOT INDICATORS ────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- ── ASK BAR ───────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bbAskBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E60D1033"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:paddingTop="6dp"
            android:visibility="gone">

            <!-- Image preview strip -->
            <LinearLayout
                android:id="@+id/bbImgPreviewRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/bbImgPreviewThumb"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_thumb_rounded"
                    android:clipToOutline="true"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/bbImgPreviewLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Image attached"
                    android:textColor="#8AABCC"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/bbImgPreviewRemove"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textSize="13sp"
                    android:textColor="#FF7070"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

            <!-- Input pill row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_ask_pill"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <!-- Camera icon -->
                <TextView
                    android:id="@+id/bbCameraBtn"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="17sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Text input (transparent — pill is the bg) -->
                <EditText
                    android:id="@+id/bbAskInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Ask about this lesson…"
                    android:textColor="#EEF0FF"
                    android:textColorHint="#4A5880"
                    android:textSize="13sp"
                    android:background="@null"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences"
                    android:maxLines="3" />

                <!-- Mic icon -->
                <TextView
                    android:id="@+id/bbMicBtn"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="🎤"
                    android:textSize="17sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Send arrow (accent circle) -->
                <TextView
                    android:id="@+id/bbAskSend"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↑"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/bg_send_circle" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── MEDIA CONTROLS ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC0D1033"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="2dp"
            android:paddingBottom="6dp">

            <!-- Slim seekbar -->
            <SeekBar
                android:id="@+id/bbProgressSeek"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:max="100"
                android:progress="0"
                android:thumbTint="#3D5AFE"
                android:progressTint="#3D5AFE"
                android:progressBackgroundTint="#1E2A50" />

            <!-- Transport row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/replayButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="↺"
                    android:textSize="19sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <TextView
                    android:id="@+id/pauseButton"
                    android:layout_width="44dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="⏸"
                    android:textSize="21sp"
                    android:textColor="#3D5AFE"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/aiTtsToggleBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:gravity="center"
                    android:text="🔊 TTS"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="#7A9ABB"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:background="@drawable/bg_tts_pill"
                    android:minWidth="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── HAND WRITER INDICATOR ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/handWriter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✍🏽"
        android:textSize="28sp"
        android:visibility="invisible" />

</FrameLayout>

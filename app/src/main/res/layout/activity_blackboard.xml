<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blackboard"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <com.aiguruapp.student.widget.BoxSpinnerView
            android:id="@+id/boxSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preparing lesson..."
            android:textColor="#E0F0FF"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#252840"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/stepCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_centerHorizontal="true"
                android:text="Step 1 / 5"
                android:textColor="#CCDDEE"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/bbQuotaChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:background="#5C5BD4"
                android:visibility="gone"
                android:text="" />

            <TextView
                android:id="@+id/closeButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center"
                android:text="✕"
                android:textColor="#AABBCC"
                android:textSize="18sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </RelativeLayout>

        <!-- Lesson content -->
        <ScrollView
            android:id="@+id/stepsScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="5dp">

            <LinearLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- Dot indicators -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- Ask-question bar (hidden for now) -->
        <LinearLayout
            android:id="@+id/bbAskBar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:visibility="gone"
            android:orientation="horizontal"
            android:background="#1A1A2E"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/bbAskInput"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:hint="Ask a question about this lesson…"
                android:textColor="#F0EDD0"
                android:textColorHint="#665557"
                android:textSize="13sp"
                android:background="#252840"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:imeOptions="actionSend"
                android:inputType="text" />

            <TextView
                android:id="@+id/bbAskSend"
                android:layout_width="44dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="↑"
                android:textSize="20sp"
                android:textColor="#5C5BD4"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="#252840"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/prevButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="◀"
                android:textSize="22sp"
                android:textColor="#AABBCC"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/pauseButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="⏸"
                android:textSize="26sp"
                android:textColor="#5C5BD4"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/replayButton"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:gravity="center"
                android:text="↺"
                android:textSize="26sp"
                android:textColor="#AABBCC"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/nextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:gravity="center"
                android:text="▶"
                android:textSize="22sp"
                android:textColor="#5C5BD4"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

    </LinearLayout>

    <!-- Hand writer indicator -->
    <TextView
        android:id="@+id/handWriter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✍🏽"
        android:textSize="28sp"
        android:visibility="invisible" />

</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blackboard"
    android:keepScreenOn="true"
    android:fitsSystemWindows="true">

    <!-- ══════════════════════════════════════════════════════════════════════
         LOADING STATE
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <com.aiguruapp.student.widget.BoxSpinnerView
            android:id="@+id/boxSpinner"
            android:layout_width="64dp"
            android:layout_height="64dp" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Preparing lesson..."
            android:textColor="#B0C8E8"
            android:textSize="15sp"
            android:gravity="center"
            android:paddingStart="32dp"
            android:paddingEnd="32dp"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════════════
         CONTENT
         ══════════════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- ── TOP BAR (fully transparent, 0dp height — replaced by floating controls) ── -->
        <!-- stepCounter kept in hierarchy (hidden) so Kotlin references still compile -->
        <TextView
            android:id="@+id/stepCounter"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

        <!-- ── LESSON CONTENT ─────────────────────────────────────────────── -->
        <ScrollView
            android:id="@+id/stepsScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="6dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- ── DOT INDICATORS ────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center" />

        <!-- ── PROGRESS HINT ("Almost done!") ────────────────────────────── -->
        <TextView
            android:id="@+id/bbProgressHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="🔥 Almost done!"
            android:textColor="#FACC15"
            android:textSize="12sp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:visibility="gone" />

        <!-- ── ASK BAR TOGGLE (always visible, collapses/expands ask bar) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#B20D1033"
            android:paddingStart="12dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp">

            <!-- Chevron toggle -->
            <TextView
                android:id="@+id/bbAskToggle"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="⌨"
                android:textSize="16sp"
                android:textColor="#7A9ABB"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <!-- Hint label -->
            <TextView
                android:id="@+id/bbAskHintLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap to ask a question…"
                android:textColor="#3A5070"
                android:textSize="12sp"
                android:paddingStart="6dp" />

            <!-- Floating quota chip -->
            <TextView
                android:id="@+id/bbQuotaChip"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_chip_indigo"
                android:visibility="gone"
                android:gravity="center"
                android:text="" />

            <!-- Save -->
            <TextView
                android:id="@+id/saveSessionBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="💾"
                android:textSize="15sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

            <!-- Publish -->
            <TextView
                android:id="@+id/publishLessonBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="📤"
                android:textSize="15sp"
                android:paddingStart="2dp"
                android:paddingEnd="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:visibility="gone" />

            <!-- Close -->
            <TextView
                android:id="@+id/closeButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="2dp"
                android:gravity="center"
                android:text="✕"
                android:textColor="#7A9ABB"
                android:textSize="16sp"
                android:background="?attr/selectableItemBackgroundBorderless" />

        </LinearLayout>

        <!-- ── ASK BAR (collapsible) ──────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bbAskBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E60D1033"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:paddingTop="6dp"
            android:visibility="gone">

            <!-- Image preview strip -->
            <LinearLayout
                android:id="@+id/bbImgPreviewRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/bbImgPreviewThumb"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_thumb_rounded"
                    android:clipToOutline="true"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/bbImgPreviewLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Image attached"
                    android:textColor="#8AABCC"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/bbImgPreviewRemove"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:gravity="center"
                    android:text="✕"
                    android:textSize="13sp"
                    android:textColor="#FF7070"
                    android:background="?attr/selectableItemBackgroundBorderless" />

            </LinearLayout>

            <!-- Input pill row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_ask_pill"
                android:paddingStart="6dp"
                android:paddingEnd="6dp">

                <!-- Camera icon -->
                <TextView
                    android:id="@+id/bbCameraBtn"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="📷"
                    android:textSize="17sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Text input (transparent — pill is the bg) -->
                <EditText
                    android:id="@+id/bbAskInput"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Ask about this lesson…"
                    android:textColor="#EEF0FF"
                    android:textColorHint="#4A5880"
                    android:textSize="13sp"
                    android:background="@null"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:imeOptions="actionSend"
                    android:inputType="textCapSentences"
                    android:maxLines="3" />

                <!-- Mic icon -->
                <TextView
                    android:id="@+id/bbMicBtn"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:gravity="center"
                    android:text="🎤"
                    android:textSize="17sp"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Send arrow (accent circle) -->
                <TextView
                    android:id="@+id/bbAskSend"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:gravity="center"
                    android:text="↑"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginStart="2dp"
                    android:background="@drawable/bg_send_circle" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── MEDIA CONTROLS ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#CC0D1033"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <!-- Thin non-interactive progress strip -->
            <ProgressBar
                android:id="@+id/bbProgressSeek"
                style="@android:style/Widget.ProgressBar.Horizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:max="100"
                android:progress="0"
                android:progressTint="#3D5AFE"
                android:progressBackgroundTint="#1E2A50" />

            <!-- Transport row: ⬅ Prev | 🔁 Replay | ▶/⏸ Play | ➡ Next | TTS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <!-- Prev step -->
                <TextView
                    android:id="@+id/prevButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="⬅"
                    android:textSize="18sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Replay -->
                <TextView
                    android:id="@+id/replayButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="↺"
                    android:textSize="19sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Play / Pause (primary, larger) -->
                <TextView
                    android:id="@+id/pauseButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:gravity="center"
                    android:text="⏸"
                    android:textSize="22sp"
                    android:textColor="#3D5AFE"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Next step -->
                <TextView
                    android:id="@+id/nextButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:text="➡"
                    android:textSize="18sp"
                    android:textColor="#5A7090"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/aiTtsToggleBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:gravity="center"
                    android:text="🔊 TTS"
                    android:textAllCaps="false"
                    android:textSize="11sp"
                    android:textColor="#7A9ABB"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:background="@drawable/bg_tts_pill"
                    android:minWidth="0dp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── HAND WRITER INDICATOR ─────────────────────────────────────────── -->
    <TextView
        android:id="@+id/handWriter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✍🏽"
        android:textSize="28sp"
        android:visibility="invisible" />

    <!-- ── SUBTITLE OVERLAY (shown while TTS speaks) ───────────────────── -->
    <!-- Floats over the board area, well above the bottom controls -->
    <TextView
        android:id="@+id/bbSubtitleTv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="220dp"
        android:background="#CC0A0E1F"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:maxLines="4"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:textColor="#F0F0F0"
        android:textSize="13sp"
        android:visibility="gone" />

</FrameLayout>

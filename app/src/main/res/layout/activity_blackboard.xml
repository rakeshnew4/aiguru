<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/blackboard"
    android:keepScreenOn="true">

    <!-- ── LOADING STATE ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/loadingGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#D4C9A8" />

        <TextView
            android:id="@+id/loadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Building your lesson…"
            android:textColor="#BCAB8A"
            android:textSize="16sp"
            android:gravity="center" />

    </LinearLayout>

    <!-- ── CONTENT STATE ───────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/contentGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header: close btn + step counter -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingLeft="4dp"
            android:paddingRight="16dp">

            <TextView
                android:id="@+id/closeButton"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:text="✕"
                android:textColor="#D4C9A8"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_centerVertical="true"
                android:alpha="0.6" />

            <TextView
                android:id="@+id/stepCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="1 / 4"
                android:textColor="#C8B87C"
                android:textSize="14sp"
                android:letterSpacing="0.08" />

        </RelativeLayout>

        <!-- Steps scroll view — cards fade in one by one as lesson progresses -->
        <ScrollView
            android:id="@+id/stepsScrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/stepsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- Progress dots -->
        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Controls: Prev | Pause | Replay | Next -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingBottom="16dp">

            <TextView
                android:id="@+id/prevButton"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="◀"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#D4C9A8" />

            <TextView
                android:id="@+id/pauseButton"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="⏸"
                android:gravity="center"
                android:textSize="28sp"
                android:textColor="#D4C9A8" />

            <TextView
                android:id="@+id/replayButton"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="↺"
                android:gravity="center"
                android:textSize="26sp"
                android:textColor="#D4C9A8" />

            <TextView
                android:id="@+id/nextButton"
                android:layout_width="64dp"
                android:layout_height="56dp"
                android:text="▶"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#D4C9A8" />

        </LinearLayout>

    </LinearLayout>

    <!-- ── FLOATING HAND-WRITER EMOJI (typewriter cursor) ──────────── -->
    <TextView
        android:id="@+id/handWriter"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="✍🏽"
        android:textSize="30sp"
        android:gravity="center"
        android:visibility="invisible"
        android:elevation="10dp"
        android:layout_gravity="top|start" />

    <!-- ── FLOATING TEACHER AVATAR (follows current step, right side) ──────── -->
    <com.example.aiguru.TeacherAvatarView
        android:id="@+id/teacherAvatar"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="60dp"
        android:elevation="8dp" />

</FrameLayout>

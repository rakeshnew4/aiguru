<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_bb_intro_sheet.xml
  Bottom sheet shown on first home-screen open to introduce Blackboard Mode.
  The user picks one of 3 sample topics and we launch BlackboardActivity for them.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/colorSurface"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="20dp"
        android:background="#CCCCCC"
        android:backgroundTint="#CCCCCC" />

    <!-- Header emoji + title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓 Discover Blackboard Mode"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/colorTextPrimary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="See how AI breaks any topic into steps, speaks each one aloud, and quizzes you at the end."
            android:textSize="14sp"
            android:textColor="@color/colorTextSecondary"
            android:lineSpacingMultiplier="1.3" />

        <!-- Feature pills row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📊 Diagrams"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔊 Voice"
                android:textSize="12sp"
                android:textColor="#2E7D32"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Quiz"
                android:textSize="12sp"
                android:textColor="#6A1B9A"
                android:background="@drawable/bg_badge_rounded"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/colorDivider"
        android:layout_marginBottom="14dp" />

    <!-- Pick a topic label -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick a topic to try:"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="@color/colorTextSecondary"
        android:paddingStart="24dp"
        android:paddingBottom="10dp" />

    <!-- Topic option: Math -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bbIntroMathCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="2dp"
        app:strokeColor="#1565C0"
        app:cardBackgroundColor="@color/colorSurface"
        app:rippleColor="#221565C0">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📐"
                android:textSize="22sp"
                android:background="#1A1565C0"
                android:backgroundTint="#1A1565C0"
                android:layout_marginEnd="14dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mathematics — Algebra"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solving quadratic equations step-by-step"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#1565C0"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Topic option: Science -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bbIntroScienceCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="2dp"
        app:strokeColor="#2E7D32"
        app:cardBackgroundColor="@color/colorSurface"
        app:rippleColor="#222E7D32">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="🔬"
                android:textSize="22sp"
                android:background="#1A2E7D32"
                android:backgroundTint="#1A2E7D32"
                android:layout_marginEnd="14dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Science — Plant Biology"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Photosynthesis explained with diagrams"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#2E7D32"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Topic option: English -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bbIntroEnglishCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="2dp"
        app:strokeColor="#6A1B9A"
        app:cardBackgroundColor="@color/colorSurface"
        app:rippleColor="#226A1B9A">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp">
            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="📝"
                android:textSize="22sp"
                android:background="#1A6A1B9A"
                android:backgroundTint="#1A6A1B9A"
                android:layout_marginEnd="14dp" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="English — Grammar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorTextPrimary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All 12 tenses explained with examples"
                    android:textSize="12sp"
                    android:textColor="@color/colorTextSecondary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="16sp"
                android:textColor="#6A1B9A"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Maybe Later -->
    <TextView
        android:id="@+id/bbIntroSkipBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="Maybe Later — I'll explore on my own"
        android:textSize="13sp"
        android:textColor="@color/colorTextSecondary"
        android:paddingTop="4dp"
        android:paddingBottom="8dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:gravity="center" />

</LinearLayout>

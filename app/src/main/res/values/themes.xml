<resources>

    <!-- Smooth slide animations for all activity transitions -->
    <style name="SlideAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <style name="Theme.AIGuru" parent="Theme.Material3.Light.NoActionBar">

        <!-- ── Smooth slide transitions for all activities ────────────── -->
        <item name="android:windowAnimationStyle">@style/SlideAnimation</item>

        <!-- ── Material3 brand color roles ────────────────────────────── -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryLight</item>
        <item name="colorOnPrimaryContainer">@color/colorPrimaryDark</item>

        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryLight</item>

        <!-- ── Surface / background ─────────────────────────────────── -->
        <item name="android:colorBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/colorTextPrimary</item>
        <item name="colorOnSurfaceVariant">@color/colorTextSecondary</item>

        <!-- ── System bars ───────────────────────────────────────────── -->
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <!-- Icon mode is set at runtime by SchoolTheme.applyStatusBar()
             which uses luminance to auto-switch between dark/light icons. -->
        <item name="android:navigationBarColor">@color/colorSurface</item>

        <!-- ── Dialogs ──────────────────────────────────────────────── -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.AIGuru.MaterialAlertDialog</item>

    </style>


    <!-- Blackboard quiz popup — dark green chalk theme -->
    <style name="Theme.BB.QuizDialog" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="colorSurface">#1A2B1A</item>
    </style>

    <!-- Dialog theme -->
    <style name="ThemeOverlay.AIGuru.MaterialAlertDialog"
        parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="buttonBarPositiveButtonStyle">@style/Widget.AIGuru.Button</item>
    </style>


    <!-- Default button style -->
    <style name="Widget.AIGuru.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!--
        Splash theme: solid dark background with no window animation,
        preventing any white flash before SplashActivity's layout inflates.
    -->
    <style name="Theme.AIGuru.Splash" parent="Theme.AIGuru">
        <item name="android:windowBackground">@color/colorPrimary</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/colorPrimary</item>
    </style>

    <!-- Full-screen immersive theme for FullscreenImageActivity -->
    <style name="Theme.AIGuru.Fullscreen" parent="Theme.AIGuru">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:colorBackground">@android:color/black</item>
    </style>

    <!-- Outlined chip style used for quick-action chips on home -->
    <style name="Widget.AIGuru.Chip.Filled" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/colorPrimaryLight</item>
        <item name="android:textColor">@color/colorPrimary</item>
    </style>

    <!-- Rounded corners overlay for ShapeableImageView in note cards -->
    <style name="RoundedCorners10" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
    </style>

</resources>
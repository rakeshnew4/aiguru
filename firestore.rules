rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── User data (own document + all subcollections) ──────────────────────────
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Allow any signed-in user to apply a referral bonus to this user's doc.
      // The claiming transaction writes bonus_questions_today to the referrer's
      // doc — only these two fields may be written this way.
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['bonus_questions_today', 'updatedAt']);

      match /{subcollection=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── Server-managed user metadata (plan, quotas, tokens) ───────────────────
    // Plan/subscription fields are written exclusively by the FastAPI server.
    // The Android client may only read, and may update the daily question counters.
    match /users_table/{userId} {
      allow read: if isOwner(userId);
      // Client may only increment the three daily-quota counter fields.
      // All other fields (plan, tokens, expiry, etc.) remain server-only.
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['chat_questions_today', 'bb_sessions_today', 'questions_updated_at']);
    }

    // ── Bootstrap / app-start collections (public read, no client write) ───────

    // Schools — needed before login (SchoolLoginActivity dropdown)
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if false;

      // Student login verification — signed-in user may read exactly their own
      // student document to verify username + password. No listing allowed.
      match /students/{username} {
        allow get: if isSignedIn();
        allow list, write: if false;
      }
    }

    // Subscription plans — shown on paywall before/after login
    match /plans/{planId} {
      allow read: if true;
      allow write: if false;
    }

    // Promotional offer banners
    match /app_offers/{offerId} {
      allow read: if true;
      allow write: if false;
    }

    // In-app broadcast notifications
    match /notifications/{notifId} {
      allow read: if true;
      allow write: if false;
    }

    // App update / maintenance config (updates/app_config)
    match /updates/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Content catalogue (public read, no client write) ───────────────────────
    match /subjects/{subjectId} {
      allow read: if true;
      allow write: if false;
    }

    match /chapters/{chapterId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Quiz content (authenticated read, server write only) ───────────────────
    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Quiz attempts (owner can read their own; server writes via service account)
    match /attempts/{attemptId} {
      allow read: if isSignedIn() && request.auth.uid == resource.data.user_id;
      allow write: if false;
    }

    // ── Payment collections (server-only via service account) ─────────────────
    match /payment_intents/{docId} {
      allow read, write: if false;
    }

    match /payment_receipts/{docId} {
      allow read, write: if false;
    }

    match /payment_webhooks/{docId} {
      allow read, write: if false;
    }

    // ── Admin / server config (readable by signed-in clients, never writable) ─
    // Android app reads admin_config/global for server URL, model tiers, and
    // maintenance messages. Writing is server-only via service account.
    match /admin_config/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Blackboard fallback cache (server-written, no client access) ──────────
    match /blackboard_cache/{docId} {
      allow read, write: if false;
    }

    // ── Student progress stats ─────────────────────────────────────────────────
    // Collection: students_stats/{userId}
    // Students read/write their own document.
    // Teachers (any signed-in user) may run a school-filtered list query.
    match /students_stats/{userId} {
      // Owner: full read + write
      allow read, write: if isOwner(userId);

      // Teacher progress view: any signed-in user may list-query by school_id.
      // The app always filters by school_id so results are school-scoped.
      allow list: if isSignedIn();
    }

    // ── Referral codes ─────────────────────────────────────────────────────────
    // Structure: referralCodes/{code} → { ownerUserId: string, ownerName: string }
    match /referralCodes/{code} {
      // Any signed-in user can read — needed to validate / look up owner during claiming
      allow read: if isSignedIn();
      // Only the owner can create or update their own code
      allow write: if isSignedIn()
        && request.resource.data.ownerUserId == request.auth.uid;
    }
  }
}

